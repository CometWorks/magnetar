# Pulsar WebUI Configuration

# HTTP server settings
WEBUI_HOST=0.0.0.0
WEBUI_PORT=8000

# Path to the Pulsar/Magnetar configuration directory
# Default: %APPDATA%\Magnetar (Windows)
# PULSAR_CONFIG_DIR=C:\Users\YourUser\AppData\Roaming\Magnetar

# Path to the Dedicated Server installation directory
# Default: auto-detected from Steam/Registry
# DS_INSTALL_DIR=C:\Program Files (x86)\Steam\steamapps\common\SpaceEngineersDedicatedServer\DedicatedServer64

# Path to the Dedicated Server configuration directory
# Default: %APPDATA%\SpaceEngineersDedicated
# DS_CONFIG_DIR=C:\Users\YourUser\AppData\Roaming\SpaceEngineersDedicated

# Admin plugin REST API endpoint (companion plugin running inside the DS)
ADMIN_API_URL=http://127.0.0.1:9000

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
